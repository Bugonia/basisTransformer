# Shared same-budget enwik8 standard Transformer baseline config.
#
# Source this file before launching comparison experiments, or pass it as:
#
#   CONFIG_FILE=experiments/configs/enwik8_standard_transformer_muon_8l_512d_ctx512_bs256_100k.env \
#     experiments/sequence_mixers/run_sequence_mixers.sh
#
# This file intentionally does not set BASE_RUN or VARIANTS, so each experiment
# script can keep its own run prefix and variant list.

# Baseline result directory used by comparison summarizers.
export STANDARD_BASE_RUN="${STANDARD_BASE_RUN:-enwik8_optimizer_sweep_standard_pre_layernorm_8l_512d_ctx512_bs256_test005_100k_earlystop10_lrdecay30k}"

# Dataset and split.
export DATA_FILE="${DATA_FILE:-data/enwik8.txt}"
export ENCODING="${ENCODING:-latin-1}"
export VAL_FRAC="${VAL_FRAC:-0.005}"
export TEST_FRAC="${TEST_FRAC:-0.005}"

# Standard Transformer architecture.
export VARIANT="${VARIANT:-standard}"
export NORM="${NORM:-pre}"
export NORM_KIND="${NORM_KIND:-layernorm}"
export NORM_SCALE="${NORM_SCALE:-learned}"
export N_LAYER="${N_LAYER:-8}"
export N_HEAD="${N_HEAD:-8}"
export N_EMBD="${N_EMBD:-512}"
export BLOCK_SIZE="${BLOCK_SIZE:-512}"
export DROPOUT="${DROPOUT:-0.1}"

# Batch, evaluation, and training budget.
export BATCH_SIZE="${BATCH_SIZE:-256}"
export MAX_ITERS="${MAX_ITERS:-100000}"
export LR_DECAY_ITERS="${LR_DECAY_ITERS:-30000}"
export WARMUP_ITERS="${WARMUP_ITERS:-500}"
export EVAL_INTERVAL="${EVAL_INTERVAL:-1000}"
export EVAL_ITERS="${EVAL_ITERS:-20}"
export EARLY_STOP_PATIENCE="${EARLY_STOP_PATIENCE:-10}"
export SEEDS="${SEEDS:-1 2}"

# Optimizer: same-budget Muon baseline.
export OPTIMIZER="${OPTIMIZER:-muon}"
export LEARNING_RATE="${LEARNING_RATE:-2e-3}"
export MIN_LR="${MIN_LR:-2e-4}"
export WEIGHT_DECAY="${WEIGHT_DECAY:-0.01}"
export ADAMW_FALLBACK_LEARNING_RATE="${ADAMW_FALLBACK_LEARNING_RATE:-2e-4}"
export BETA1="${BETA1:-0.9}"
export BETA2="${BETA2:-0.95}"
export MUON_MOMENTUM="${MUON_MOMENTUM:-0.95}"
export MUON_NS_STEPS="${MUON_NS_STEPS:-5}"

# Runtime defaults used on H100/H200-class GPUs.
export PYTHON_BIN="${PYTHON_BIN:-.venv_cu128/bin/python}"
export TRAIN_SCRIPT="${TRAIN_SCRIPT:-train_block_residuals.py}"
export DTYPE="${DTYPE:-bfloat16}"
export COMPILE="${COMPILE:-0}"
export RESUME="${RESUME:-1}"

# Optimizer-sweep compatibility. Override SPECS explicitly when you want to
# re-run AdamW and Muon together.
export MUON_SPEC="${MUON_SPEC:-muon:2e-3:2e-4}"
export ADAMW_SPEC="${ADAMW_SPEC:-adamw:2e-4:2e-5}"
export ADAMW_WEIGHT_DECAY="${ADAMW_WEIGHT_DECAY:-0.1}"
export MUON_WEIGHT_DECAY="${MUON_WEIGHT_DECAY:-0.01}"
